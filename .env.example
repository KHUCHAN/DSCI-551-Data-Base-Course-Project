# Optional local overrides for Hybrid-AML scripts.
# The scripts work without this file; export only the values you want to change.

IMAGE_NAME=apache/age:latest
CONTAINER_NAME=apache-age
DB_NAME=hybrid_aml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
HOST_PORT=5455
DB_VOLUME=age_pg18data
RESET_DB_VOLUME=0
BENCHMARK_RUNS=20
